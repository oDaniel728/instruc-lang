new def @load
    req comments
    req std
    req stacks
end def

new def @main
    new stack $
    new stack left
    new stack right
    new stack merged

    use stack left
        load 1
        load 2

    use stack right
        load 3
        load 4

    use stack $
        stack merge left right > merged
        stack load merged
        call std@print
    end stack *
end def

new def @quit
end def
