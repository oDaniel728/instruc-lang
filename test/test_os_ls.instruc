new def @load
    req std
    req str
    req os
    req comments
    req stacks
    # os cd "./test"
end def

new def @main
    new stack 0
    new stack $
    
    use stack $
        
        stack run os ls as 0
        stack run stack expand .:- into 0 as 0
        stack run kill i 0 as 0

        stack run print as 0

    end stack *
end def

new def @quit
end def