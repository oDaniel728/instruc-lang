new def @load
    req comments
    req std
    req math
    req stacks
end def

new def @main
    new stack $
    new stack data
    new stack result

    use stack data
        load 5
        load 15
        load 25

    use stack $
        stack call math@opsum as data > result
        stack load result
        call std@printf
    end stack *
end def

new def @quit
end def
